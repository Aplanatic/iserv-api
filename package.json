{
  "name": "iserv-api",
  "version": "1.3.2",
  "description": "Unofficial TypeScript SDK for IServ school management servers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude=\"tests/live/**\"",
    "test:live": "vitest run tests/live/get-routes.live.test.ts --testTimeout 60000",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "iserv",
    "school",
    "api",
    "sdk"
  ],
  "author": "yonn2222",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YONN2222/IservAPI"
  },
  "homepage": "https://github.com/YONN2222/IservAPI#readme",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "got": "^15.0.5",
    "nodemailer": "^8.0.7",
    "tough-cookie": "^6.0.1",
    "webdav": "^5.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/nodemailer": "^8.0.0",
    "@types/tough-cookie": "^4.0.5",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
