{
  "name": "@aplanatic/iserv-api",
  "version": "1.8.10",
  "description": "Unofficial typed SDK, route catalog, and local explorer for IServ school servers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./catalog": {
      "import": {
        "types": "./dist/catalog.d.mts",
        "default": "./dist/catalog.mjs"
      },
      "require": {
        "types": "./dist/catalog.d.cts",
        "default": "./dist/catalog.cjs"
      }
    },
    "./redaction": {
      "import": {
        "types": "./dist/redaction.d.mts",
        "default": "./dist/redaction.mjs"
      },
      "require": {
        "types": "./dist/redaction.d.cts",
        "default": "./dist/redaction.cjs"
      }
    }
  },
  "files": [
    "dist",
    "explorer/dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude=\"tests/live/**\"",
    "test:live": "vitest run tests/live/get-routes.live.test.ts --testTimeout 60000",
    "explorer:dev": "npm --prefix explorer run dev",
    "explorer:build": "npm --prefix explorer run build",
    "check:sensitive": "node scripts/check-sensitive.mjs",
    "check": "npm run check:sensitive && npm run lint && npm run typecheck && npm test && npm run build && npm run explorer:build",
    "prepare": "npm run build",
    "prepack": "npm run build && npm ci --prefix explorer --ignore-scripts && npm run explorer:build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "iserv",
    "school",
    "api",
    "sdk"
  ],
  "author": "Aplanatic",
  "contributors": [
    "YONN2222 and IservAPI contributors"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aplanatic/iserv-api.git"
  },
  "homepage": "https://github.com/Aplanatic/iserv-api#readme",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT",
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.21",
    "got": "^15.1.0",
    "nodemailer": "^9.0.3",
    "playwright-core": "^1.61.1",
    "tough-cookie": "^6.0.2",
    "webdav": "^5.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/nodemailer": "^8.0.1",
    "@types/tough-cookie": "^4.0.5",
    "tsdown": "^0.22.11",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
